# Local SQLite
LESSON_PROGRESS_DATA_DIR=./data

# Vercel persistent storage
# Set one of these in the Vercel project settings or through a Marketplace Postgres integration.
# If these are missing on Vercel, the app falls back to in-memory storage.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
DATABASE_URL=
